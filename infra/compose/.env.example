# Optional overrides — the stack runs WITHOUT this file (defaults are local-only values).
# cp .env.example .env  # then edit
#
# NOTE: compose interpolation prefers your SHELL environment over .env — an exported
# ANTHROPIC_API_KEY in your shell silently arms the real-money oracle. Unset it or set it here
# deliberately. Keep a real key OUT of this directory while running scripts/verify.sh (its
# secret scan greps infra/ *.env*; only *.example is filtered).

# Local postgres password (local-dev value, not a secret — the DB binds 127.0.0.1 only)
POSTGRES_PASSWORD=localdev

# Empty = the oracle/JD endpoints return honest 503s. Set a real key to use the oracle locally.
ANTHROPIC_API_KEY=

# Grafana admin login (anonymous read-only works without it)
GRAFANA_ADMIN_PASSWORD=localdev
